# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/interq

# JWT secret — use any long random string (e.g. generate at https://randomkeygen.com)
JWT_SECRET=your_super_secret_jwt_key_here

# OpenRouter API key — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Your deployed Vercel frontend URL (set after client is deployed)
CLIENT_URL=https://your-interq-client.vercel.app

# Environment
NODE_ENV=production
